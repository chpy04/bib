  "prompt": "build a basic counter app",
  "component_code": "export default function App() {\n  const [count, setCount] = React.useState(0);\n\n  const increment = () => setCount(count + 1);\n  const decrement = () => setCount(count - 1);\n  const reset = () => setCount(0);\n\n  return (\n    <div className=\"flex items-center justify-center min-h-screen bg-gray-100\">\n      <Card className=\"w-80\">\n        <CardHeader className=\"text-center\">\n          <CardTitle>Counter App</CardTitle>\n          <CardDescription>A simple counter application</CardDescription>\n        </CardHeader>\n        <CardContent className=\"text-center\">\n          <div className=\"text-6xl font-bold text-blue-600 mb-8\">\n            {count}\n          </div>\n          <div className=\"flex gap-4 justify-center\">\n            <Button \n              onClick={decrement}\n              variant=\"outline\"\n              size=\"lg\"\n              className=\"w-16 h-16 text-xl\"\n            >\n              -\n            </Button>\n            <Button \n              onClick={reset}\n              variant=\"secondary\"\n              size=\"lg\"\n              className=\"px-6\"\n            >\n              Reset\n            </Button>\n            <Button \n              onClick={increment}\n              size=\"lg\"\n              className=\"w-16 h-16 text-xl\"\n            >\n              +\n            </Button>\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}",
